                        <div style="font-size: 1.5rem; font-weight: 800; color: var(--navy-deep);">@(hotel.NumberOfRooms * 2) Units</div>
                    </div>
                    <div class="card" style="padding: 1.5rem; border: 1px solid var(--border-color);">
