@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script>
      function switchTab(tabName) {
        $('.tab-link').removeClass('active');
        $(`.tab-link[data-tab="${tabName}"]`).addClass('active');
        $('.tab-content').hide();
        $(`#${tabName}Tab`).show();
        
        if (tabName === 'overview') {
            $('#dynamicSubTitle').text('Manage your property branches and registry information');
            $('#branchEditorHeader').hide();
            $('#registrySidebarContainer').hide();
        }
        
        if (tabName === 'editor') {
            initMap();
            setTimeout(() => { if (map) map.invalidateSize(); }, 200);
        }
    }

    // Checkbox Sync Logic
    $(document).on('change', '.sync-checkbox', function() {
        const isChecked = $(this).is(':checked');
        const targetId = $(this).data('target');
        const callback = $(this).data('toggle-callback');

        // Update hidden input
        $('#' + targetId).val(isChecked ? "true" : "false");

        // Special callbacks
        if (callback && typeof window[callback] === 'function') {
            window[callback](isChecked);
        }
    });

    // Toggle Group Logic
    $(document).on('click', '.toggle-item', function() {
        const value = $(this).data('value');
        const $group = $(this).closest('.toggle-group');
        const targetId = $group.data('target');
        const callback = $group.data('toggle-callback');

        // Update visual state
        $group.find('.toggle-item').removeClass('active');
        $(this).addClass('active');

        // Update hidden input
        $('#' + targetId).val(value);

        // Special callbacks
        if (callback && typeof window[callback] === 'function') {
            window[callback](value);
        }
    });

    function togglePoolType(val) {
        const isTrue = (val === true || val === "true");
        $('#poolTypeGroup').toggle(isTrue);
    }

    function toggleSpaGender(val) {
        const isTrue = (val === true || val === "true");
        $('#spaGenderGroup').toggle(isTrue);
    }

    function syncToggleGroups() {
        // Sync checkboxes
        $('.sync-checkbox').each(function() {
            const $chk = $(this);
            const targetId = $chk.data('target');
            const value = $('#' + targetId).val();
            const isChecked = (value === 'true' || value === true);
            
            $chk.prop('checked', isChecked);
            
            // Trigger callbacks
            const callback = $chk.data('toggle-callback');
            if (callback && typeof window[callback] === 'function') {
                window[callback](isChecked);
            }
        });

        // Sync old-style toggle groups
        $('.toggle-group').each(function() {
            const $group = $(this);
            const targetId = $group.data('target');
            const value = $('#' + targetId).val();
            
            $group.find('.toggle-item').removeClass('active');
            $group.find(`.toggle-item[data-value="${value}"]`).addClass('active');
            
            const callback = $group.data('toggle-callback');
            if (callback && typeof window[callback] === 'function') {
                window[callback](value);
            }
        });
    }

        async function loadBranchRegistry(branchDescription, branchCode, tin, unitId) {
            $('#editorConsigneeUnitId').val(unitId);
            $('#activeBranchName').text(branchDescription);
            $('#dynamicSubTitle').text('Editing Branch: ' + branchDescription);
            $('#editorConsigneeId').val('@hotel.Id'); // Default ID
            $('#editorTradeName').val('@hotel.TradeName'); // Default TradeName
            
            $('#branchEditorHeader').show();
            switchTab('editor');

            $('.collapsible-content').hide();
            $('.collapsible-card').removeClass('active');
            $('.collapsible-card:first-child').addClass('active').find('.collapsible-content').show();

            try {
                const response = await fetch(`/HotelOwner/GetBranchRegistry?consigneeUnitId=${unitId}`);
                if (response.ok) {
                    const hotel = await response.json();
                    
                    // Populate Hidden IDs
                    $('#editorConsigneeId').val(hotel.id);
                    $('#editorConsigneeUnitId').val(hotel.consigneeUnitId);
                    $('#editorTradeName').val(hotel.name);

                    // Populate Basic Info
                    $('#form-trade-name').val(hotel.name);
                    $('#form-registration-name').val(hotel.registrationName);
                    $('#form-address').val(hotel.specificAddress);
                    $('#form-subcity-basic').val(hotel.subcity);
                    $('#form-airport-dist').val(hotel.distanceFromAirport);
                    $('#form-star-cat').val(hotel.starCategory);
                    $('#form-total-rooms').val(hotel.totalRooms);
                    $('#form-total-beds').val(hotel.totalBeds);
                    $('#form-contact-info').val(hotel.contactInformation);
                    $('#form-res-contact').val(hotel.reservationsContact);
                    $('#form-sust-focal').val(hotel.sustainabilityFocalPoint);

                    // Populate Accommodation
                    $('#form-king-rooms').val(hotel.kingSizeRooms);
                    $('#form-twin-rooms').val(hotel.twinBedRooms);
                    $('#form-junior-suites').val(hotel.juniorSuites);
                    $('#form-suites').val(hotel.suites);
                    $('#form-pres-suites').val(hotel.presidentialSuites);
                    $('#form-acc-rooms').val(hotel.accessibleRooms);

                    // Populate F&B
