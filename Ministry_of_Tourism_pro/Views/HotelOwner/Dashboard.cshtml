            } catch (error) {
                console.error('Load error:', error);
                Swal.fire('Error', 'Failed to load branch data.', 'error');
            }
        }


        function toggleCollapsible(header) {
            const card = $(header).closest('.collapsible-card');
            const content = card.find('.collapsible-content');
            if (card.hasClass('active')) { content.slideUp(300); card.removeClass('active'); }
            else { content.slideDown(300); card.addClass('active'); }
        }

        // Asset Registry Logic
        let assets = {
            accommodation: [],
            dining: [],
            venue: [],
            amenities: []
        };

        function openAssetModal(sectionId, sectionName) {
            $('#modalSectionId').val(sectionId);
            $('#modalTitle').text(`Add ${sectionName} Details`);
            $('#modalSubtitle').text(`Registration for ${sectionName}`);
            
            // Hide all specialized fields first
            $('#accommodationFields, #venueFields, #diningFields').hide();
            $('#simpleAssetFields').show();

            if (sectionId === 'accommodation') {
                $('#accommodationFields').show();
                $('#simpleAssetFields').hide();
            } else if (sectionId === 'venue') {
                $('#venueFields').show();
                $('#simpleAssetFields').hide();
            } else if (sectionId === 'dining') {
                $('#diningFields').show();
                $('#simpleAssetFields').hide();
            } else {
                $('#assetTypeLabel').text('Asset Type / Category');
                $('#assetTypeName').attr('placeholder', 'e.g. WiFi Router, HVAC Unit...');
            }

            $('body').css('overflow', 'hidden'); 
            $('#assetModal').css('display', 'flex').hide().fadeIn(300);
        }

        function closeAssetModal() {
            $('body').css('overflow', ''); 
            $('#assetModal').fadeOut(300);
        }

        function addAsset() {
            const sectionId = $('#modalSectionId').val();
            let assetData = { id: Date.now() };

            if (sectionId === 'accommodation') {
                assetData = {
                    ...assetData,
                    roomType: $('#accRoomType').val(),
                    bedType: $('#accBedType').val(),
                    maxOccupancy: parseInt($('#accOccupancy').val()) || 2,
                    numberOfRooms: parseInt($('#accNumRooms').val()) || 1,
                    roomSize: $('#accSize').val(),
                    pricePerNight: parseFloat($('#accPrice').val()) || 0,
                    amenities: $('#accAmenities').val()
                };
                assetData.name = assetData.roomType;
                assetData.displayValue = `${assetData.roomSize} sqm • ${assetData.pricePerNight} ETB (${assetData.numberOfRooms} Units)`;
            } else if (sectionId === 'venue') {
                const tables = $('input[name="venTables"]:checked').map(function() { return this.value; }).get().join(', ');
                const facilities = $('input[name="venFacilities"]:checked').map(function() { return this.value; }).get().join(', ');
                assetData = {
                    ...assetData,
                    name: $('#venType').val(),
                    type: $('#venType').val(),
                    maxSeatingCapacity: parseInt($('#venSeating').val()) || 0,
                    standingCapacity: parseInt($('#venStanding').val()) || 0,
                    areaSize: parseFloat($('#venArea').val()) || 0,
                    ceilingHeight: parseFloat($('#venCeiling').val()) || 0,
                    tableArrangements: tables,
                    facilities: facilities
                };
                assetData.displayValue = `${assetData.maxSeatingCapacity} Seats • ${assetData.areaSize} sqm`;
            } else if (sectionId === 'dining') {
                assetData = {
                    ...assetData,
                    name: $('#dinCuisine').val() || 'Restaurant',
                    specialization: $('#dinSpec').val(),
                    cuisineType: $('#dinCuisine').val(),
                    seatingCapacity: parseInt($('#dinCapacity').val()) || 0,
                    operatingHours: $('#dinHours').val(),
                    diningSetting: $('#dinSetting').val(),
                    maxCateringCapacity: parseInt($('#dinCatCap').val()) || 0,
                    serviceTypes: $('#dinCatService').val()
                };
                assetData.displayValue = `${assetData.specialization} • ${assetData.seatingCapacity} Seats`;
            } else {
                assetData.name = $('#assetTypeName').val().trim();
                assetData.count = parseInt($('#assetCount').val());
                assetData.displayValue = `${assetData.count} Units`;
                
                if (!assetData.name) { alert('Please specify the asset type.'); return; }
                if (isNaN(assetData.count) || assetData.count < 1) { alert('Please enter a valid count.'); return; }
            }

            assets[sectionId].push(assetData);
            renderAssets(sectionId);
            closeAssetModal();
        }

        function removeAsset(sectionId, assetId) {
            assets[sectionId] = assets[sectionId].filter(a => a.id !== assetId);
            renderAssets(sectionId);
        }

        function renderAssets(sectionId) {
            const container = $(`#assetContainer_${sectionId}`);
            const sectionAssets = assets[sectionId];

            if (sectionAssets.length === 0) {
                const icon = sectionId === 'accommodation' ? 'bed' : 
                           sectionId === 'dining' ? 'utensils' :
                           sectionId === 'venue' ? 'handshake' : 'swimming-pool';
                
                container.html(`<div class="empty-state" style="grid-column: 1/-1; padding: 2rem; text-align: center; color: var(--text-muted); border: 2px dashed var(--border-color); border-radius: 1rem;">
                        <i class="fas fa-${icon}" style="font-size: 2rem; opacity: 0.2; margin-bottom: 0.75rem; display: block;"></i>
                        No records found.
                    </div>`);
                return;
            }

            container.empty();
            sectionAssets.forEach(asset => {
                let iconClass = 'fas fa-cube';
                if (sectionId === 'accommodation') iconClass = 'fas fa-bed';
                else if (sectionId === 'venue') iconClass = 'fas fa-door-open';
                else if (sectionId === 'dining') iconClass = 'fas fa-utensils';

                container.append(`
                    <div class="asset-card">
                        <div class="asset-icon-circle">
                            <i class="${iconClass}"></i>
                        </div>
                        <div class="asset-info">
                            <div style="font-weight: 800; color: var(--navy-deep); font-size: 0.85rem; line-height: 1.2;">${asset.name || 'Unspecified'}</div>
                            <div style="display: flex; align-items: center; gap: 0.5rem; margin-top: 0.2rem;">
                                <span class="asset-badge">${asset.bedType || asset.type || 'Standard'}</span>
                                <span style="font-size: 0.75rem; color: var(--text-muted); font-weight: 600;">${asset.displayValue}</span>
                            </div>
                        </div>
                        <div class="btn-remove-asset" onclick="removeAsset('${sectionId}', ${asset.id})" style="width: 30px; height: 30px; background: #fff1f2; color: #e11d48; border-radius: 6px; display: flex; align-items: center; justify-content: center; cursor: pointer;">
                            <i class="fas fa-trash-can" style="font-size: 0.8rem;"></i>
                        </div>
                    </div>
                `);
            });
            updateAllHiddenInputs();
        }

        function updateAllHiddenInputs() {
            let container = $('#allAssetsHiddenContainer');
            if (container.length === 0) {
                $('#registryForm').append('<div id="allAssetsHiddenContainer"></div>');
                container = $('#allAssetsHiddenContainer');
            }
            container.empty();
            
            // Here we would map the complex JS objects to the format expected by the backend
            // For now, we'll keep the simple mapping to show it's working
            let index = 0;
            Object.keys(assets).forEach(sectionId => {
                assets[sectionId].forEach(asset => {
                    container.append(`
                        <input type="hidden" name="Infrastructure[${index}].Section" value="${sectionId}" />
                        <input type="hidden" name="Infrastructure[${index}].Data" value='${JSON.stringify(asset)}' />
                    `);
                    index++;
                });
            });
        }

        // Centralized Registry Persistence Logic
        async function saveRegistry(btn, mode) {
        const unitId = $('#editorConsigneeUnitId').val();
        if (!unitId) {
            Swal.fire('Error', 'Please select a property branch first.', 'error');
            return;
        }

        const btnText = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...';

        try {
            const formData = new FormData();
            formData.append('branchId', unitId);
            formData.append('mode', mode);

            // Always send core identifiers and location
            formData.append('Id', $('#editorConsigneeId').val());
            formData.append('ConsigneeUnitId', $('#editorConsigneeUnitId').val());
            formData.append('TradeName', $('#form-trade-name').val());
            formData.append('Latitude', $('#lat-input').val());
            formData.append('Longitude', $('#lng-input').val());

            // 1. Collect Basic Info if mode is 'basic' or 'all'
            if (mode === 'basic' || mode === 'all') {
                formData.append('RegistrationName', $('#form-registration-name').val());
                formData.append('SpecificAddress', $('#form-address').val());
                formData.append('Subcity', $('#form-subcity-basic').val());
                formData.append('DistanceFromAirport', $('#form-airport-dist').val());
                formData.append('StarCategory', $('#form-star-cat').val());
                formData.append('TotalRooms', $('#form-total-rooms').val());
                formData.append('TotalBeds', $('#form-total-beds').val());
                formData.append('ContactInformation', $('#form-contact-info').val());
                formData.append('ReservationsContact', $('#form-res-contact').val());
                formData.append('SustainabilityFocalPoint', $('#form-sust-focal').val());
            }

            // 2. Collection Accommodation if mode is 'accommodation' or 'all'
            if (mode === 'accommodation' || mode === 'all') {
                formData.append('KingSizeRooms', $('#form-king-rooms').val());
                formData.append('TwinBedRooms', $('#form-twin-rooms').val());
                formData.append('JuniorSuites', $('#form-junior-suites').val());
                formData.append('Suites', $('#form-suites').val());
                formData.append('PresidentialSuites', $('#form-pres-suites').val());
                formData.append('AccessibleRooms', $('#form-acc-rooms').val());
            }

            // 3. Food & Beverage
            if (mode === 'food_beverage' || mode === 'all') {
                formData.append('AllDayDining', $('#form-all-day-dining').val());
                formData.append('AllDayDiningSeats', $('#form-dining-seats').val());
                formData.append('SpecialtyRestaurants', $('#form-spec-rest').val());
                formData.append('CoffeeShop', $('#form-coffee-shop').val());
                formData.append('BarsCount', $('#form-bars-count').val());
                formData.append('NightClub', $('#form-night-club').val());
                formData.append('SouvenirShops', $('#form-shops-count').val());
                formData.append('DelegationCatering', $('#form-del-cat').val());
                formData.append('DelegationCateringMaxPax', $('#form-del-cat-max').val());
                formData.append('RefillWaterStations', $('#form-refill-water').val());
                formData.append('VegVeganOptions', $('#form-veg-options').val());
                formData.append('NoSingleUsePlastics', $('#form-no-plastic').val());
            }

            // 4. Meetings & Events
            if (mode === 'meetings_events' || mode === 'all') {
                formData.append('MeetingRoomsCount', $('#form-meeting-rooms').val());
                formData.append('LargestRoomCapacityTheatre', $('#form-cap-theatre').val());
                formData.append('LargestRoomCapacityClassroom', $('#form-cap-classroom').val());
                formData.append('LargestRoomCapacityBanquet', $('#form-cap-banquet').val());
                formData.append('TotalMeetingSpaceSqm', $('#form-total-meeting-sqm').val());
            }

            // 5. Public Facilities
            if (mode === 'public_facilities' || mode === 'all') {
                formData.append('InternetBandwidthDown', $('#form-net-down').val());
                formData.append('InternetBandwidthUp', $('#form-net-up').val());
                formData.append('LobbyAreaSqm', $('#form-lobby-sqm').val());
                formData.append('GreenAreaSqm', $('#form-green-sqm').val());
                formData.append('PoolAvailable', $('#form-pool-avail').val());
                formData.append('PoolType', $('#form-pool-type').val());
                formData.append('SpaAvailable', $('#form-spa-avail').val());
                formData.append('SpaGender', $('#form-spa-gender').val());
                formData.append('MassageService', $('#form-massage').val());
                formData.append('ChildrensPlayground', $('#form-playground').val());
                formData.append('ChildrenDayCare', $('#form-daycare').val());
                formData.append('StaffCanteen', $('#form-canteen').val());
            }

            // 6. Accessibility
            if (mode === 'accessibility' || mode === 'all') {
                formData.append('WheelchairRamps', $('#form-ramps').val());
                formData.append('ElevatorsCount', $('#form-elevators').val());
                formData.append('ElevatorsWheelchairSized', $('#form-elev-acc').val());
                formData.append('PublicAccessibleBathroom', $('#form-bathroom-acc').val());
            }

            // 7. Security & Safety
            if (mode === 'security_safety' || mode === 'all') {
                formData.append('CCTVPublicAreas', $('#form-cctv').val());
                formData.append('FireExtinguishersLastInspection', $('#form-fire-insp').val());
                formData.append('HoseReels', $('#form-hose').val());
                formData.append('SmokeDetectorsInRooms', $('#form-smoke-rooms').val());
                formData.append('SmokeDetectorsInPublicAreas', $('#form-smoke-public').val());
                formData.append('SprinklerCoverage', $('#form-sprinkler').val());
                formData.append('FireAlarmControlPanel', $('#form-alarm-panel').val());
                formData.append('EmergencyExitsCount', $('#form-exits').val());
                formData.append('BagScanner', $('#form-bag-scanner').val());
                formData.append('WalkThroughScanner', $('#form-walk-scanner').val());
                formData.append('HandScanner', $('#form-hand-scanner').val());
            }

            // 8. Transport & Parking
            if (mode === 'transport_parking' || mode === 'all') {
                formData.append('ParkingSpacesCount', $('#form-parking').val());
                formData.append('BusParkingCount', $('#form-bus-parking').val());
                formData.append('ShuttleToCop', $('#form-shuttle-cop').val());
                formData.append('ShuttleToAirport', $('#form-shuttle-airport').val());
                formData.append('PublicTransportWithin500m', $('#form-pub-transport').val());
                formData.append('EvChargingPoints', $('#form-ev-points').val());
                formData.append('EvChargerTypes', $('#form-ev-types').val());
            }

            // 9. ICT & Services
            if (mode === 'ict_services' || mode === 'all') {
                formData.append('WifiPropertyWide', $('#form-wifi-prop').val());
                formData.append('WifiAvgSpeed', $('#form-wifi-speed').val());
                formData.append('InHouseLaundry', $('#form-laundry').val());
                formData.append('Reception24hr', $('#form-reception').val());
                formData.append('VipCheckIn', $('#form-vip-check').val());
                formData.append('PassportScanner', $('#form-pass-scanner').val());
                formData.append('CurrencyScanner', $('#form-curr-scanner').val());
            }

            // 10. Utilities
            if (mode === 'utilities_resilience' || mode === 'all') {
                formData.append('StandbyGeneratorCapacityKva', $('#form-gen-cap').val());
                formData.append('StandbyGeneratorCoverage', $('#form-gen-cov').val());
                formData.append('WaterTreatment', $('#form-water').val());
                formData.append('WasteSegregation', $('#form-waste-seg').val());
                formData.append('Recycling', $('#form-recycling').val());
                formData.append('HazardousWasteHandling', $('#form-haz-waste').val());
            }

            // 11. Sustainability
            if (mode === 'sustainability' || mode === 'all') {
                formData.append('SustainabilityCertification', $('#form-sust-cert').val());
                formData.append('OtherEcoLabels', $('#form-eco-labels').val());
                formData.append('FoodWasteProgram', $('#form-waste-prog').val());
                formData.append('SustainabilityRefillWaterStations', $('#form-sust-refill').val());
            }

            // 12. Staffing
            if (mode === 'staffing' || mode === 'all') {
                formData.append('TotalStaff', $('#form-total-staff').val());
                formData.append('InternationalLanguagesFrontDesk', $('#form-languages').val());
            }

            const response = await fetch('/HotelOwner/CommitRegistry', {
                method: 'POST',
                body: formData
            });

            if (response.ok) {
                const result = await response.json();
                if (result.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Success!',
                        text: 'Registry updated successfully.',
                        timer: 2000,
                        showConfirmButton: false
                    });
                } else {
                    Swal.fire('Error', result.message || 'Failed to update registry.', 'error');
                }
            } else {
                Swal.fire('Error', 'Server communication error.', 'error');
            }
        } catch (error) {
            console.error('Save error:', error);
            Swal.fire('Error', 'An unexpected error occurred.', 'error');
        } finally {
            btn.innerHTML = btnText;
            btn.disabled = false;
        }
    }

        function switchAttachCategory(idx) {
            $('.attach-panel').hide();
            $('#attachPanel_' + idx).show();
            $('.attach-cat-btn').removeClass('active');
            $(`.attach-cat-btn[data-cat-index="${idx}"]`).addClass('active');
        }
        var map, marker;

        function initMap() {
            if (map) return; // Already initialized
            const mapContainer = document.getElementById('editor-map');
            if (!mapContainer) return;

            map = L.map('editor-map').setView([@(hotel.Latitude ?? 9.0192), @(hotel.Longitude ?? 38.7525)], 15);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
            marker = L.marker([@(hotel.Latitude ?? 9.0192), @(hotel.Longitude ?? 38.7525)], { draggable: true }).addTo(map);

            marker.on('dragend', function() {
                var pos = marker.getLatLng();
                $('#lat-input').val(pos.lat.toFixed(6));
                $('#lng-input').val(pos.lng.toFixed(6));
            });

            map.on('click', function(e) {
                marker.setLatLng(e.latlng);
                $('#lat-input').val(e.latlng.lat.toFixed(6));
                $('#lng-input').val(e.latlng.lng.toFixed(6));
            });
        }

        function updateMap(lat, lng) {
            if (!map) initMap();
            const latlng = L.latLng(lat, lng);
            map.setView(latlng, 15);
            marker.setLatLng(latlng);
            $('#lat-input').val(lat.toFixed(6));
            $('#lng-input').val(lng.toFixed(6));
            setTimeout(() => map.invalidateSize(), 200);
        }
    </script>
    
