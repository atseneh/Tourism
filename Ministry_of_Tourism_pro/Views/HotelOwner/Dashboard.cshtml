    <script>
        // --- Navigation & Scroll Logic ---
        function scrollToSection(index) {
            const sections = $('.collapsible-card');
            if (index >= sections.length) return;
            
            const target = $(sections[index]);
            
            // Expand if collapsed
            if (!target.hasClass('active')) {
                toggleCollapsible(target.find('.collapsible-header')[0]);
            }
            
            // Scroll with offset for header/tabs
            const offset = target.offset().top - 150;
            $('html, body').animate({ scrollTop: offset }, 600);
            
            // Update sidebar active state
            updateSidebarNav(index);
        }

        function updateSidebarNav(index) {
            $('.registry-nav-item').removeClass('active');
            $('.registry-nav-item').eq(index).addClass('active');
        }

        // Scroll Spy Implementation
        $(window).scroll(function() {
            if ($('#editorTab').is(':visible')) {
                const scrollPos = $(document).scrollTop() + 200;
                $('.collapsible-card').each(function(i) {
                    const top = $(this).offset().top;
                    const bottom = top + $(this).outerHeight();
                    if (scrollPos >= top && scrollPos <= bottom) {
                        updateSidebarNav(i);
                    }
                });
            }
        });

        // --- Branch Summary Logic ---
        // Category label mapping
        const catMeta = {
            basic:             { label: 'Basic Info',           icon: 'fas fa-id-card' },
            accommodation:     { label: 'Accommodation',        icon: 'fas fa-bed' },
            food_beverage:     { label: 'Food & Beverage',      icon: 'fas fa-utensils' },
            meetings_events:   { label: 'Meetings & Events',    icon: 'fas fa-handshake' },
            public_facilities: { label: 'Public Facilities',    icon: 'fas fa-building' },
            accessibility:     { label: 'Accessibility',        icon: 'fas fa-wheelchair' },
            security_safety:   { label: 'Security & Safety',    icon: 'fas fa-shield-halved' },
            transport_parking: { label: 'Transport & Parking',  icon: 'fas fa-car' },
            ict_services:      { label: 'ICT & Guest Services', icon: 'fas fa-wifi' },
            utilities_resilience: { label: 'Utilities & Resilience', icon: 'fas fa-bolt' },
            sustainability:    { label: 'Sustainability',       icon: 'fas fa-leaf' },
            staffing:          { label: 'Staffing & Languages', icon: 'fas fa-users' }
        };

        // Map IdentificationDTO Description -> category key using CNET_WebConstantes category IDs
        const fieldCatMap = {
            RegistrationName:'basic', DistanceFromAirport:'basic', StarCategory:'basic', TotalRooms:'basic', TotalBeds:'basic', ContactInformation:'basic', ReservationsContact:'basic', SustainabilityFocalPoint:'basic',
