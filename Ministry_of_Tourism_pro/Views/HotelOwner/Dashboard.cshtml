                    $('#form-waste-seg').val(String(hotel.wasteSegregation));
                    $('#form-recycling').val(String(hotel.recycling));
                    $('#form-haz-waste').val(String(hotel.hazardousWasteHandling));

                    // Populate Sustainability
                    $('#form-sust-cert').val(hotel.sustainabilityCertification);
                    $('#form-eco-labels').val(hotel.otherEcoLabels);
                    $('#form-waste-prog').val(String(hotel.foodWasteProgram));
                    $('#form-sust-refill').val(String(hotel.sustainabilityRefillWaterStations));

                    $('#form-total-staff').val(hotel.totalStaff);
                    $('#form-languages').val(hotel.internationalLanguagesFrontDesk);

                    syncToggleGroups();
                    updateMap(hotel.latitude || 9.03, hotel.longitude || 38.74);
