@model IEnumerable<Ministry_of_Tourism_pro.Application.DTOs.HotelDto>
@using Ministry_of_Tourism_pro.WebConstants
@{
    var hotel = Model.FirstOrDefault() ?? new Ministry_of_Tourism_pro.Application.DTOs.HotelDto();
    ViewData["Title"] = $"{hotel.Name} • Registry Profile";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    .profile-tab-animate {
        animation: slideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    
    h3 {
        font-size: 1.1rem;
        font-weight: 800;
        margin: 0;
    }
    
    .collapsible-card {
        background: white;
        border-radius: 1rem;
        border: 1px solid var(--border-color);
        margin-bottom: 1rem;
        overflow: hidden;
        transition: all 0.3s ease;
    }
    
    .collapsible-card.active {
        box-shadow: var(--shadow-md);
        border-color: var(--primary-color);
    }
    
    .collapsible-header {
        padding: 1.25rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        cursor: pointer;
        background: white;
        user-select: none;
    }
    
    .collapsible-header:hover { background: var(--bg-muted); }
    
    .collapsible-header .chevron {
        transition: transform 0.3s ease;
        color: var(--text-muted);
    }
    
    .collapsible-card.active .collapsible-header .chevron {
        transform: rotate(180deg);
        color: var(--primary-color);
    }
    
    .collapsible-content { border-top: 1px solid var(--border-color); padding: 1.25rem 1.5rem; display: none; }
    .collapsible-card.active .collapsible-content { display: block; }

    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem 1.5rem; }
    .full-width { grid-column: span 2; }
    .form-label { font-weight: 700; color: var(--navy-deep); margin-bottom: 0.25rem; display: block; font-size: 0.8rem; }
    .form-control { border-radius: 0.6rem; padding: 0.45rem 0.85rem; border: 1.5px solid var(--border-color); width: 100%; transition: border-color 0.2s; font-size: 0.9rem; }
    .form-control:focus { border-color: var(--primary-color); outline: none; }

    .glass-card {
        background: white !important;
        border: 1px solid var(--border-color);
        border-radius: 1rem;
        box-shadow: var(--shadow-sm);
    }

    .map-container { height: 350px; border-radius: 1rem; border: 1.5px solid var(--border-color); overflow: hidden; margin-top: 10px; }
    
    @@keyframes slideUp {
        from { transform: translateY(15px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }

    .modal-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(6px);
        z-index: 10000;
        overflow-y: auto;
        padding: 2rem 1rem;
        display: none; /* Controlled by JS */
        justify-content: center;
        align-items: flex-start; /* Better for tall modals */
    }

    .modal-content-animate {
        animation: modalFadeUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        position: relative;
        margin: auto; /* Centers horizontally and vertically in flex items if combined with specific settings */
        z-index: 10001;
        width: 100%;
        max-width: 750px;
    }

    @@keyframes modalFadeUp {
        from { transform: translateY(30px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }

    /* Branch specific styles */
    .btn-branch-long {
        width: 100%; background: white; border: 1.5px solid var(--border-color); border-radius: 1.25rem; padding: 1.25rem 1.75rem;
        display: flex; align-items: center; gap: 1.5rem; cursor: pointer; transition: all 0.2s ease; margin-bottom: 1rem;
        text-align: left; position: relative; overflow: hidden;
    }
    .btn-branch-long:hover {
        border-color: var(--primary-color); background: var(--bg-muted); transform: translateY(-3px); box-shadow: var(--shadow-md);
    }
    .btn-branch-long .branch-icon {
        width: 54px; height: 54px; background: var(--bg-muted); border-radius: 50%; display: flex; align-items: center; 
        justify-content: center; font-size: 1.25rem; color: var(--primary-color); font-weight: 800; border: 1.5px solid var(--border-color);
    }
    .btn-branch-long:hover .branch-icon { background: var(--primary-color); color: white; border-color: var(--primary-color); }

    .btn-create-branch {
        width: 100%; background: transparent; border: 2px dashed var(--border-color); border-radius: 1.25rem; padding: 1.5rem;
        color: var(--text-muted); font-weight: 700; cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center; gap: 0.75rem;
    }
    .btn-create-branch:hover { background: var(--bg-muted); border-color: var(--primary-color); color: var(--primary-color); }

    /* Attachment Old Format Support */
    .attach-cat-btn {
        width: 100%; text-align: left; background: transparent; border: none; border-left: 3px solid transparent; 
        padding: 0.65rem 1.25rem; font-size: 0.875rem; font-weight: 500; color: var(--text-muted); cursor: pointer; transition: all .15s;
    }
    .attach-cat-btn.active {
        background: white; border-left-color: var(--primary-color); font-weight: 700; color: var(--navy-deep);
    }
    .attach-dropzone {
        border: 2px dashed var(--border-color); border-radius: 0.75rem; padding: 1.75rem; text-align: center; background: var(--bg-muted); cursor: pointer; transition: border-color .2s;
    }
    .attach-dropzone:hover { border-color: var(--primary-color); }

    /* Asset Grid Styles */
    .asset-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 1.25rem;
        margin-top: 0.5rem;
    }
    .asset-card {
        background: white !important;
        border: 1px solid var(--border-color);
        border-radius: 0.75rem;
        padding: 0.75rem 1rem;
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center;
        gap: 1rem;
        transition: all 0.2s ease;
        position: relative;
        border-left: 3px solid var(--primary-color);
    }
    .asset-card:hover { 
        border-color: var(--primary-color); 
        box-shadow: var(--shadow-sm);
        transform: translateY(-2px);
    }
    .asset-icon-circle {
        width: 36px;
        height: 36px;
        background: var(--bg-muted);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary-color);
        font-size: 0.9rem;
    }
    .asset-badge {
        font-size: 0.65rem;
        font-weight: 800;
        text-transform: uppercase;
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
        background: var(--bg-muted);
        color: var(--text-muted);
    }
    .asset-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; width: 4px; height: 100%;
        background: var(--primary-color);
        opacity: 0;
        transition: opacity 0.3s;
    }
    .asset-card:hover::before { opacity: 1; }
    
    .asset-info { display: flex; flex-direction: column; gap: 0.25rem; }
    .asset-name { font-weight: 800; color: var(--navy-deep); font-size: 0.95rem; }
    .asset-value { font-size: 1.25rem; font-weight: 900; color: var(--primary-color); display: flex; align-items: baseline; gap: 0.35rem; }
    .asset-value span { font-size: 0.75rem; color: var(--text-muted); font-weight: 700; text-transform: uppercase; }
    
    .btn-remove-asset { 
        width: 32px; height: 32px; 
        display: flex; align-items: center; justify-content: center;
        color: #ef4444; cursor: pointer; border-radius: 50%; 
        transition: all 0.2s; border: 1px solid transparent;
    }
    .btn-remove-asset:hover { background: #fee2e2; border-color: #fecaca; }

    .btn-save-section {
        background: var(--bg-muted);
        color: var(--navy-deep);
        border: 1px solid var(--border-color);
        padding: 0.4rem 0.8rem;
        border-radius: 0.5rem;
        font-size: 0.75rem;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        transition: all 0.2s;
    }
    .btn-save-section:hover {
        background: #10b981;
        color: white;
        border-color: #10b981;
    }
    .form-group-inline {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.5rem;
        padding: 0.65rem 0;
        border-bottom: 1px solid #f1f5f9;
    }
    .form-group-inline .form-label {
        margin-bottom: 0;
        flex: 0 0 280px;
        font-size: 0.85rem;
        color: var(--navy-deep);
        padding-right: 1.5rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .form-group-inline .form-control,
    .form-group-inline .toggle-group {
        flex: 1;
        min-width: 0; /* Allow shrinking if needed */
    }
    .form-group-inline .form-control {
        text-align: left; /* Switched to left for better multi-word visibility */
    }
    .form-group-inline .premium-checkbox {
        flex-shrink: 0;
        min-width: 140px;
    }
    .form-group-inline .toggle-group {
        display: flex;
        justify-content: flex-start;
    }
    .form-group-inline:last-child {
        border-bottom: none;
    }

    .premium-checkbox {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        cursor: pointer;
        user-select: none;
        padding: 0.4rem 0.75rem;
        border-radius: 0.75rem;
        border: 1.5px solid var(--border-color);
        transition: all 0.2s ease;
        background: white;
        width: fit-content;
        min-width: 110px;
        justify-content: space-between;
    }
    .premium-checkbox:hover {
        border-color: var(--primary-color);
        background: white;
        box-shadow: var(--shadow-sm);
    }
    .premium-checkbox input { display: none; }
    .checkbox-box {
        width: 22px;
        height: 22px;
        border: 2px solid #cbd5e1;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
        background: white;
    }
    .premium-checkbox input:checked ~ .checkbox-box {
        background: var(--primary-color);
        border-color: var(--primary-color);
    }
    .premium-checkbox .checkbox-box i {
        color: white;
        font-size: 0.8rem;
        opacity: 0;
        transform: scale(0.5);
        transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .premium-checkbox input:checked ~ .checkbox-box i {
        opacity: 1;
        transform: scale(1);
    }
    .premium-checkbox .checkbox-text {
        font-size: 0.85rem;
        font-weight: 700;
        color: var(--text-muted);
        transition: color 0.2s;
    }
    .premium-checkbox input:checked ~ .checkbox-text {
        color: var(--navy-deep);
    }

    /* Keep toggle group for 3-way choices if needed, but match style */
    .toggle-group {
        display: flex;
        background: #f8fafc;
        padding: 0.25rem;
        border-radius: 0.75rem;
        border: 1.5px solid var(--border-color);
        gap: 0.25rem;
    }
    .toggle-item {
        flex: 1;
        padding: 0.4rem 0.75rem;
        text-align: center;
        border-radius: 0.5rem;
        font-size: 0.75rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.2s;
        color: var(--text-muted);
    }
    .toggle-item.active {
        background: white;
        color: var(--primary-color);
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--border-color);
    }

    /* Sidebar Navigation Styles */
    .registry-layout {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 2rem;
        align-items: start;
    }
    /* Sidebar Sub-Navigation Styles */
    .registry-subnav {
        margin: 0.5rem 0.5rem 0.5rem 2.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        border-left: 1.5px solid var(--border-color);
        padding-left: 0.75rem;
    }
    .registry-nav-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.5rem 0.75rem;
        border-radius: 0.5rem;
        color: var(--text-muted);
        font-weight: 600;
        font-size: 0.8rem;
        cursor: pointer;
        transition: all 0.2s;
    }
    .registry-nav-item:hover {
        background: var(--bg-muted);
        color: var(--primary-color);
    }
    .registry-nav-item.active {
        background: #eef2ff;
        color: var(--primary-color);
        font-weight: 700;
    }
    .registry-nav-item i {
        width: 14px;
        text-align: center;
        font-size: 0.85rem;
    }

    /* Branch Detail Panel Styles */
    .detail-overlay {
        display: block;
        position: fixed;
        top: 0; right: 0; width: 40vw; height: 100%;
        background: white;
        box-shadow: -15px 0 45px rgba(0,0,0,0.12);
        z-index: 11000;
        padding: 0;
        overflow-y: auto;
        transform: translateX(100%);
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        visibility: hidden;
        display: flex;
        flex-direction: column;
    }
    .detail-overlay.active { transform: translateX(0); visibility: visible; }
    .detail-panel-header {
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--border-color);
        position: sticky;
        top: 0;
        background: white;
        z-index: 2;
    }
    .detail-panel-body {
        flex: 1;
        overflow-y: auto;
        padding: 1rem 1.5rem 2rem;
    }
    .detail-search-bar {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--bg-muted);
        border: 1px solid var(--border-color);
        border-radius: 0.6rem;
        padding: 0.4rem 0.75rem;
        margin-bottom: 0.75rem;
    }
    .detail-search-bar input {
        border: none;
        background: transparent;
        outline: none;
        font-size: 0.85rem;
        color: var(--text-dark);
        flex: 1;
        font-family: inherit;
    }
    .detail-filter-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin-bottom: 1rem;
    }
    .detail-chip {
        padding: 0.25rem 0.7rem;
        border-radius: 999px;
        font-size: 0.72rem;
        font-weight: 700;
        border: 1.5px solid var(--border-color);
        background: white;
        color: var(--text-muted);
        cursor: pointer;
        transition: all 0.15s;
        white-space: nowrap;
    }
    .detail-chip:hover, .detail-chip.active {
        background: var(--primary-color);
        color: white;
        border-color: var(--primary-color);
    }
    .detail-cat-card {
        border: 1px solid var(--border-color);
        border-radius: 0.75rem;
        margin-bottom: 0.75rem;
        overflow: hidden;
    }
    .detail-cat-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.6rem 1rem;
        background: var(--bg-muted);
        cursor: pointer;
        user-select: none;
        gap: 0.5rem;
    }
    .detail-cat-header:hover { background: #e8f5f5; }
    .detail-cat-title {
        font-size: 0.75rem;
        font-weight: 800;
        color: var(--navy-deep);
        text-transform: uppercase;
        letter-spacing: 0.04em;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .detail-cat-chevron {
        color: var(--text-muted);
        font-size: 0.7rem;
        transition: transform 0.25s;
    }
    .detail-cat-card.open .detail-cat-chevron { transform: rotate(180deg); color: var(--primary-color); }
    .detail-cat-body {
        display: none;
        padding: 0.5rem 1rem 0.75rem;
    }
    .detail-cat-card.open .detail-cat-body { display: block; }
    
    .detail-backdrop {
        display: none;
        position: fixed;
        top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(15, 23, 42, 0.3);
        backdrop-filter: blur(4px);
        z-index: 10999;
    }
    
    .detail-header {
        margin-bottom: 2rem;
        border-bottom: 1px solid var(--border-color);
        padding-bottom: 1.5rem;
    }
    .detail-section {
        margin-bottom: 2.5rem;
    }
    .detail-section-title {
        font-size: 0.75rem;
        font-weight: 800;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        border-left: 3px solid var(--primary-color);
        padding-left: 0.75rem;
    }
    .detail-row {
        display: flex;
        justify-content: space-between;
        padding: 0.75rem 0;
        border-bottom: 1px solid #f8fafc;
    }
    .detail-label { color: #64748b; font-size: 0.9rem; font-weight: 600; }
    .detail-value { color: var(--navy-deep); font-weight: 800; font-size: 0.9rem; text-align: right; }
    
    .update-btn-top {
        background: var(--primary-color);
        color: white;
        padding: 0.4rem 1rem;
        border-radius: 0.6rem;
        font-weight: 700;
        font-size: 0.78rem;
        border: none;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        transition: all 0.2s;
        white-space: nowrap;
    }
    .update-btn-top:hover { background: var(--navy-deep); transform: translateY(-1px); }

    @@media (max-width: 1024px) {
        .registry-layout { grid-template-columns: 1fr; }
        .registry-sidebar { display: none; }
        .detail-overlay { width: 100%; }
    }
</style>

@section SidebarSubNav {
    <div id="registrySidebarContainer" style="display: none;">
        <div class="registry-subnav">
            <div style="padding-bottom: 0.5rem; margin-bottom: 0.5rem; border-bottom: 1px solid var(--border-color);">
                <div id="sidebarBranchName" style="font-weight: 800; color: var(--navy-deep); font-size: 0.75rem; text-transform: uppercase;">...</div>
            </div>
            <div class="registry-nav-item active" onclick="scrollToSection(0)">
                <i class="fas fa-id-card"></i> Basic Info
            </div>
            <div class="registry-nav-item" onclick="scrollToSection(1)">
                <i class="fas fa-bed"></i> Accommodation
            </div>
            <div class="registry-nav-item" onclick="scrollToSection(2)">
                <i class="fas fa-utensils"></i> Food & Beverage
            </div>
            <div class="registry-nav-item" onclick="scrollToSection(3)">
                <i class="fas fa-handshake"></i> Events
            </div>
            <div class="registry-nav-item" onclick="scrollToSection(4)">
                <i class="fas fa-building"></i> Facilities
            </div>
            <div class="registry-nav-item" onclick="scrollToSection(5)">
                <i class="fas fa-wheelchair"></i> Accessibility
            </div>
            <div class="registry-nav-item" onclick="scrollToSection(6)">
                <i class="fas fa-shield-halved"></i> Security & Safety
            </div>
            <div class="registry-nav-item" onclick="scrollToSection(7)">
                <i class="fas fa-car"></i> Transport & Parking
            </div>
            <div class="registry-nav-item" onclick="scrollToSection(8)">
                <i class="fas fa-wifi"></i> ICT & Guest Services
            </div>
            <div class="registry-nav-item" onclick="scrollToSection(9)">
                <i class="fas fa-bolt"></i> Utilities & Resilience
            </div>
            <div class="registry-nav-item" onclick="scrollToSection(10)">
                <i class="fas fa-leaf"></i> Sustainability
            </div>
            <div class="registry-nav-item" onclick="scrollToSection(11)">
                <i class="fas fa-users"></i> Staffing & Languages
            </div>
            <div class="registry-nav-item" onclick="scrollToSection(12)">
                <i class="fas fa-paperclip"></i> Attachments
            </div>
            <div style="margin-top: 0.75rem; padding-top: 0.75rem; border-top: 1px solid var(--border-color);">
                <button type="button" class="btn btn-primary w-100" style="padding: 0.4rem; border-radius: 0.5rem; font-size: 0.72rem; font-weight: 800;" onclick="saveRegistry(this, 'all')">
                    <i class="fas fa-save"></i> Commit All
                </button>
            </div>
        </div>
    </div>
}

<div class="animate-fade-in">

    <!-- Compact Header Section -->
    <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 2rem; border-bottom: 1px solid var(--border-color); padding-bottom: 1rem; position: relative; z-index: 1;">
        <div style="display: flex; align-items: center; gap: 1.25rem;">
            <div style="width: 50px; height: 50px; background: white; border-radius: 12px; display: flex; align-items: center; justify-content: center; box-shadow: var(--shadow-sm); border: 1px solid var(--border-color); padding: 8px;">
                <img src="~/logo/logo.svg" alt="Logo" style="width: 100%; height: 100%; object-fit: contain;" />
            </div>
            <div>
                <h1 style="color: var(--navy-deep); font-weight: 800; margin: 0; font-size: 1.75rem; letter-spacing: -0.5px;">@hotel.Name</h1>
                <p id="dynamicSubTitle" style="color: var(--text-muted); margin: 0.25rem 0 0; font-size: 0.95rem; font-weight: 600;">Manage your property branches and registry information</p>
            </div>
        </div>
        
        <!-- Compact Navigation Tabs -->
        <div class="dashboard-tabs" style="margin-bottom: -1rem; border: none; padding: 0; gap: 2rem;">
            <button class="tab-link active" data-tab="overview" style="padding: 1rem 0; font-size: 0.9rem; font-weight: 700;">
                <i class="fas fa-id-card-clip" style="margin-right: 0.5rem;"></i>Overview
            </button>
        </div>
    </div>

    <!-- Tab Contents -->
    <div id="overviewTab" class="tab-content profile-tab-animate">
        <div style="display: grid; grid-template-columns: 1fr 350px; gap: 2.5rem;">
            <div>
                <!-- Branch Registry Section (Replaces Narrative as requested) -->
                <div class="glass-card" style="padding: 2.5rem; margin-bottom: 2rem;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
                        <h3 style="color: var(--navy-deep); font-weight: 800; margin: 0;"><i class="fas fa-code-branch" style="color: var(--primary-color);"></i> Branch Portfolio</h3>
                        <div style="font-size: 0.85rem; color: var(--text-muted); font-weight: 600;">ACTIVE BRANCHES: 2</div>
                    </div>
                    
                    <div style="display: grid; gap: 1rem;">
                        @foreach (var (b, index) in Model.Select((value, i) => (value, i)))
                        {
                            var jsonIds = Newtonsoft.Json.JsonConvert.SerializeObject(b.RawIdentifications.Select(id => new { id.Description, id.IdNumber }));
                            <!-- Branch @(index + 1) -->
                            <div class="btn-branch-long" onclick='showBranchSummary("@b.TradeName", "@b.ConsigneeUnitDescription", "@b.Code", "@b.TIN", "@b.ConsigneeUnitId", "@b.City", "@b.StarCategory", "@b.TotalRooms", "@b.TotalBeds", @Html.Raw(jsonIds))'>
                                <div class="branch-icon">@((index + 1).ToString("D2"))</div>
                                <div style="flex: 1;">
                                    <div style="font-weight: 800; color: var(--navy-deep); font-size: 1.05rem; margin-bottom: 0.25rem;">@b.TradeName - @b.ConsigneeUnitDescription</div>
                                    <div style="display: flex; gap: 1rem; font-size: 0.8rem; color: var(--text-muted); font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;">
                                        <span>RID: #@b.Id.ToString("D5")</span>
                                        @if (!string.IsNullOrEmpty(b.TIN)) { <span>TIN: @b.TIN</span> }
                                        <span><i class="fas fa-location-dot"></i> @b.City</span>
                                    </div>
                                </div>
                                <div style="display: flex; align-items: center; gap: 0.75rem;">
                                    <span class="badge" onclick='event.stopPropagation(); loadBranchRegistry("@b.ConsigneeUnitDescription", "@b.Code", "@b.TIN", "@b.ConsigneeUnitId")' style="background: var(--primary-color); color: white; border-radius: 0.75rem; padding: 0.6rem 1.25rem;">See and Update</span>
                                    <i class="fas fa-chevron-right" style="color: var(--border-color);"></i>
                                </div>
                            </div>
                        }

                        <!-- Create Branch -->
                        <button type="button" class="btn-create-branch" onclick="alert('Initializing New Branch Registry...')">
                            <i class="fas fa-plus-circle" style="font-size: 1.25rem;"></i> Create New Property Branch
                        </button>
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
                    <div class="card" style="padding: 1.5rem; border: 1px solid var(--border-color);">
