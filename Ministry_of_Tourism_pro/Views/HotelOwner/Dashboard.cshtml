        let _currentIdentifications = [];
        let _currentSummaryUnitId = '';
        let _currentSummaryUnitCode = '';
        let _currentSummaryUnitTin = '';
        let _currentSummaryUnitDesc = '';

        function showBranchSummary(tradeName, unitDesc, code, tin, unitId, city, category, rooms, beds, identifications) {
            _currentIdentifications = identifications || [];
            _currentSummaryUnitId = unitId;
            _currentSummaryUnitCode = code;
            _currentSummaryUnitTin = tin;
            _currentSummaryUnitDesc = unitDesc;

            $('#summaryTradeName').text(tradeName);
            $('#summaryUnitDesc').text(unitDesc);
            $('#summaryCode').text(code || 'N/A');
            $('#summaryTin').text('TIN: ' + (tin || 'N/A'));
            $('#summaryLocation').text(city || 'Addis Ababa');
            $('#summaryCategory').text(category || 'General Sector');
            $('#summaryRooms').text((rooms || '0') + ' Units');
            $('#summaryBeds').text((beds || '0') + ' Units');
            
           
            // Reset filter chips and search
            $('#summarySearchInput').val('');
            $('.detail-chip').removeClass('active');
            $('.detail-chip[data-cat="all"]').addClass('active');

            renderDynamicSections('all', '');

            $('#detailBackdrop').fadeIn(300);
            $('#branchSummaryPanel').addClass('active');
            $('body').css('overflow', 'hidden');
        }

        function renderDynamicSections(activeCat, searchTerm) {
            const container = $('#summaryDynamicSections');
            container.empty();
            
            // 1. Gather existing data Map
            const dataMap = {};
            (_currentIdentifications || []).forEach(id => {
                dataMap[id.Description] = id.IdNumber;
            });

            // 2. Group all fields from fieldCatMap (the master list)
            const grouped = {};
            Object.keys(fieldCatMap).forEach(fieldName => {
                const catKey = fieldCatMap[fieldName];
                if (!grouped[catKey]) grouped[catKey] = [];
                
                let rawVal = dataMap[fieldName];
                let displayVal = '';
                
                if (rawVal === undefined || rawVal === null || rawVal === '') {
                    // Fallback logic for hidden/zero fields
                    if (fieldName.toLowerCase().includes('count') || fieldName.toLowerCase().includes('rooms') || fieldName.toLowerCase().includes('beds') || fieldName.toLowerCase().includes('capacity')) {
                        displayVal = '0';
                    } else {
                        displayVal = '<span style="color:#94a3b8; font-style:italic;">Not Specified</span>';
                    }
                } else if (rawVal === 'True') {
                    displayVal = '<span style="color:#059669;font-weight:800;"><i class="fas fa-check-circle"></i> Yes</span>';
                } else if (rawVal === 'False') {
                    displayVal = '<span style="color:#94a3b8;font-weight:700;"><i class="fas fa-minus-circle"></i> No</span>';
                } else {
                    displayVal = rawVal;
                }

                const labelDisplay = fieldName.replace(/([A-Z])/g, ' $1').trim();
                
                // Search filter
                const isMatch = !searchTerm || 
                                labelDisplay.toLowerCase().includes(searchTerm.toLowerCase()) || 
                                String(rawVal || '').toLowerCase().includes(searchTerm.toLowerCase());

                if (isMatch) {
                    grouped[catKey].push({
                        label: labelDisplay,
                        value: displayVal
                    });
                }
            });

            // 3. Render Categories following the display order in catMeta
            Object.keys(catMeta).forEach(catKey => {
                const items = grouped[catKey] || [];
                if (items.length === 0) return;

                // Category filter
                if (activeCat !== 'all' && catKey !== activeCat) return;

                const meta = catMeta[catKey];
                let rowsHtml = items.map(item => `
                    <div class="detail-row">
                        <span class="detail-label" style="font-size:0.8rem;">${item.label}</span>
                        <span class="detail-value" style="font-size:0.8rem;">${item.value}</span>
                    </div>`).join('');

                container.append(`
                    <div class="detail-cat-card open" data-category="${catKey}">
                        <div class="detail-cat-header" onclick="toggleDetailCat(this)">
                            <span class="detail-cat-title"><i class="${meta.icon}"></i> ${meta.label}</span>
                            <i class="fas fa-chevron-down detail-cat-chevron"></i>
                        </div>
                        <div class="detail-cat-body" style="display:block;">${rowsHtml}</div>
                    </div>
                `);
            });
            // Reset collapse/expand button state
            $('#toggleAllCardsText').text('Collapse All');
            $('#toggleAllCardsIcon').removeClass('fa-expand-alt').addClass('fa-compress-alt');

            if (container.children().length === 0) {
                container.html(`<div style="text-align:center; padding: 2rem; color: var(--text-muted); font-size:0.85rem;"><i class="fas fa-search" style="font-size:1.5rem; opacity:0.2; display:block; margin-bottom:0.5rem;"></i>No matching fields found</div>`);
            }
        }

        function filterByCategoryDropdown(val) {
            const search = $('#summarySearchInput').val();
            if (val === 'all') {
                renderDynamicSections('all', search);
            } else {
                // Re-render but only show selected category card
                renderDynamicSections('all', search);
                $('#summaryDynamicSections .detail-cat-card').each(function() {
                    if ($(this).data('category') !== val) {
                        $(this).hide();
                    } else {
                        $(this).show();
                        // Ensure it stays open
                        $(this).addClass('open');
                        $(this).find('.detail-cat-body').show();
                        $(this).find('.detail-cat-chevron').css('transform', 'rotate(180deg)');
                    }
                });
            }
        }

        function filterSummaryFields() {
            const search = $('#summarySearchInput').val();
            const activeCat = $('#summaryCategorySelect').val() || 'all';
            filterByCategoryDropdown(activeCat);
        }

        function toggleDetailCat(header) {
            const card = $(header).closest('.detail-cat-card');
            const body = card.find('.detail-cat-body');
            const chevron = card.find('.detail-cat-chevron');
            if (card.hasClass('open')) {
                card.removeClass('open');
                body.slideUp(200);
                chevron.css('transform', 'rotate(0deg)').css('color', 'var(--text-muted)');
            } else {
                card.addClass('open');
                body.slideDown(200);
                chevron.css('transform', 'rotate(180deg)').css('color', 'var(--primary-color)');
            }
        }

        function toggleAllDetailCats() {
            const cards = $('#summaryDynamicSections .detail-cat-card:visible');
            const anyOpen = cards.filter('.open').length > 0;
            if (anyOpen) {
                // Collapse all
                cards.each(function() {
                    $(this).removeClass('open');
                    $(this).find('.detail-cat-body').slideUp(200);
                    $(this).find('.detail-cat-chevron').css('transform', 'rotate(0deg)').css('color', 'var(--text-muted)');
                });
                $('#toggleAllCardsText').text('Expand All');
                $('#toggleAllCardsIcon').removeClass('fa-compress-alt').addClass('fa-expand-alt');
            } else {
                // Expand all
                cards.each(function() {
                    $(this).addClass('open');
                    $(this).find('.detail-cat-body').slideDown(200);
                    $(this).find('.detail-cat-chevron').css('transform', 'rotate(180deg)').css('color', 'var(--primary-color)');
                });
                $('#toggleAllCardsText').text('Collapse All');
                $('#toggleAllCardsIcon').removeClass('fa-expand-alt').addClass('fa-compress-alt');
            }
        }


        function hideBranchSummary() {
            $('#detailBackdrop').fadeOut(300);
            $('#branchSummaryPanel').removeClass('active');
            $('body').css('overflow', '');
        }

        // Override original loadBranchRegistry to handle UI transitions and sidebar
        const originalLoadRegistry = loadBranchRegistry;
        loadBranchRegistry = async function(branchDescription, branchCode, tin, unitId) {
            hideBranchSummary();
            $('#sidebarBranchName').text(branchDescription);
            $('#registrySidebarContainer').show(); // Show sidebar in global nav
            await originalLoadRegistry(branchDescription, branchCode, tin, unitId);
            updateSidebarNav(0);
        };

        $(document).ready(function() {
            $('.tab-link').on('click', function() { switchTab($(this).data('tab')); });
            
            // If we want to hide the branch header when switching back manually
            $('.tab-link[data-tab="overview"]').on('click', function() {
                $('#branchEditorHeader').hide();
            });

            syncToggleGroups();
        });
    </script>
}
