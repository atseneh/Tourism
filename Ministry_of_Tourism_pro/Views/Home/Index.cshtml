@{
    ViewData["Title"] = "National Dashboard";
}

<div class="animate-fade-in">
    <div style="margin-bottom: 2.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 1.5rem;">
        <div style="display: flex; justify-content: space-between; align-items: flex-end;">
            <div>
                <h1 style="font-weight: 800; color: var(--navy-deep); margin: 0; letter-spacing: -1px;">National Command Center</h1>
                <p style="color: var(--text-muted); margin-top: 0.5rem; font-size: 1.1rem;">Real-time situational awareness across the Tourism Registry.</p>
            </div>
            <div class="text-end" style="font-size: 0.85rem; color: var(--text-muted);">
                <i class="fas fa-clock" style="margin-right: 0.4rem;"></i> Last System Sync: @DateTime.Now.ToString("HH:mm")
            </div>
        </div>
    </div>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="stats-grid">
            <div class="stat-card">
                <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                    <span class="stat-value">1,280</span>
                    <i class="fas fa-users" style="color: var(--primary-color); font-size: 1.25rem; opacity: 0.5;"></i>
                </div>
                <span class="stat-label">Total Users</span>
            </div>
            <div class="stat-card">
                <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                    <span class="stat-value">256</span>
                    <i class="fas fa-building" style="color: #10b981; font-size: 1.25rem; opacity: 0.5;"></i>
                </div>
                <span class="stat-label">Active Hoteliers</span>
            </div>
            <div class="stat-card" style="border-left: 4px solid #ef4444;">
                <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                    <span class="stat-value">12</span>
                    <i class="fas fa-triangle-exclamation" style="color: #ef4444; font-size: 1.25rem; opacity: 0.5;"></i>
                </div>
                <span class="stat-label">System Alerts</span>
            </div>
        </div>

        <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 2.5rem; margin-top: 2.5rem;">
            <div class="glass-card">
                <h3 style="color: var(--navy-deep); font-weight: 800; margin-bottom: 2rem; display: flex; align-items: center; gap: 0.75rem;">
                    <i class="fas fa-server" style="color: var(--primary-color);"></i> Infrastructure Status
                </h3>
                
                <div style="display: flex; flex-direction: column; gap: 1.5rem;">
                    <div style="display: flex; justify-content: space-between; padding-bottom: 1rem; border-bottom: 1px solid var(--border-color);">
                        <div>
                            <div style="font-weight: 700; color: var(--navy-deep);">Registry Cache Node</div>
                            <div style="font-size: 0.85rem; color: var(--text-muted);">Sync frequency: 5m • Healthy</div>
                        </div>
                        <span class="badge badge-approved" style="height: fit-content;">OPERATIONAL</span>
                    </div>
                    <div style="display: flex; justify-content: space-between; padding-bottom: 1rem; border-bottom: 1px solid var(--border-color);">
                        <div>
                            <div style="font-weight: 700; color: var(--navy-deep);">Auth Gateway v2.4</div>
                            <div style="font-size: 0.85rem; color: var(--text-muted);">Latency: 42ms • Stable</div>
                        </div>
                        <span class="badge badge-approved" style="height: fit-content;">OPERATIONAL</span>
                    </div>
                </div>
            </div>

            <div class="glass-card" style="background: var(--navy-deep); color: white; border: none;">
                <h4 style="font-weight: 800; margin-bottom: 1.5rem;">Registry Health</h4>
                <div style="margin-bottom: 2rem;">
                    <div style="display: flex; justify-content: space-between; font-size: 0.85rem; margin-bottom: 0.5rem;">
                        <span>Data Integrity</span>
                        <span>98%</span>
                    </div>
                    <div style="width: 100%; height: 6px; background: rgba(255,255,255,0.1); border-radius: 10px;">
                        <div style="width: 98%; height: 100%; background: #10b981; border-radius: 10px;"></div>
                    </div>
                </div>
                <div>
                    <div style="display: flex; justify-content: space-between; font-size: 0.85rem; margin-bottom: 0.5rem;">
                        <span>Uptime (30d)</span>
                        <span>99.9%</span>
                    </div>
                    <div style="width: 100%; height: 6px; background: rgba(255,255,255,0.1); border-radius: 10px;">
                        <div style="width: 99.9%; height: 100%; background: var(--primary-light); border-radius: 10px;"></div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="hero-card">
            <h1 style="font-size: 3.5rem; font-weight: 800; margin-bottom: 1rem; letter-spacing: -2px;">ETHIOPIA</h1>
            <p style="font-size: 1.5rem; font-weight: 300; opacity: 0.9;">Land of Origins &bull; Tourism Management Portal</p>
            <div style="margin-top: 3rem; display: flex; gap: 1rem; justify-content: center;">
                <a asp-controller="Account" asp-action="Register" class="btn-premium" style="background: white; color: var(--primary-color);">Get Started</a>
                <a asp-controller="Account" asp-action="Login" class="btn-premium btn-secondary" style="border-color: rgba(255,255,255,0.3); color: white;">Officer Access</a>
            </div>
        </div>
    }
</div>
