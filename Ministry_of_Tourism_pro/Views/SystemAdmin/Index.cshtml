@using CNET_V7_Domain.Domain.ViewSchema
@using Newtonsoft.Json
@model List<VwUserPersonDTO>
@{
    ViewData["Title"] = "User Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --primary: #4f46e5;
        --secondary: #6366f1;
        --bg-glass: rgba(255, 255, 255, 0.85);
        --border-glass: rgba(255, 255, 255, 0.3);
        --row-height: 28px; 
    }

    body {
        background-color: #f8fafc;
        font-family: 'Inter', -apple-system, sans-serif;
    }

    .premium-header {
        background: linear-gradient(135deg, #1e1b4b 0%, #4338ca 100%);
        padding: 1.5rem 2rem;
        color: white;
        border-radius: 1rem;
        margin: 1rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    }

    .premium-header h1 {
        margin: 0;
        font-size: 1.5rem;
        font-weight: 800;
        letter-spacing: -0.5px;
    }

    .premium-header p {
        margin: 0;
        opacity: 0.8;
        font-size: 0.875rem;
    }

    .btn-add {
        background: white;
        color: var(--primary);
        border: none;
        padding: 0.6rem 1.2rem;
        border-radius: 0.75rem;
        font-weight: 700;
        font-size: 0.875rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    .btn-add:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        background: #f1f5f9;
        color: var(--primary);
    }

    .table-container {
        margin: 1rem;
        background: white;
        border-radius: 1rem;
        border: 1px solid #e2e8f0;
        overflow: hidden;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }

    .toolbar {
        padding: 0.75rem 1rem;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #fafbfc;
    }

    .search-box {
        position: relative;
        width: 300px;
    }

    .search-box i {
        position: absolute;
        left: 0.75rem;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        font-size: 0.9rem;
    }

    .search-box input {
        width: 100%;
        padding: 0.5rem 1rem 0.5rem 2.25rem;
        border: 1px solid #e2e8f0;
        border-radius: 0.5rem;
        font-size: 0.8rem;
        outline: none;
        transition: border-color 0.2s;
    }

    .search-box input:focus {
        border-color: var(--primary);
    }

    .grid-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 11px;
    }

    .grid-table thead th {
        background: #f8fafc;
        color: #64748b;
        text-transform: uppercase;
        font-weight: 700;
        font-size: 10px;
        letter-spacing: 0.5px;
        padding: 8px 12px;
        border-bottom: 2px solid #f1f5f9;
        text-align: left;
        position: sticky;
        top: 0;
        z-index: 10;
    }

    .grid-table tr {
        height: var(--row-height);
        border-bottom: 1px solid #f1f5f9;
        transition: background 0.1s;
    }

    .grid-table tr:hover {
        background: #f1f5f9;
    }

    .grid-table td {
        padding: 0 12px;
        color: #334155;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 150px;
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-weight: 700;
        padding: 2px 6px;
        border-radius: 4px;
    }

    .status-active { color: #16a34a; background: #f0fdf4; }
    .status-inactive { color: #94a3b8; background: #f8fafc; }

    .action-btn {
        padding: 2px 4px;
        border: none;
        background: none;
        color: #64748b;
        cursor: pointer;
        transition: color 0.2s;
        font-size: 12px;
    }

    .action-btn:hover { color: var(--primary); }
    .action-btn.delete:hover { color: #ef4444; }

    /* Modal Styling */
    .modal-content {
        border-radius: 1.25rem;
        border: none;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    }

    .modal-header {
        border-bottom: 1px solid #f1f5f9;
        padding: 1.25rem 1.5rem;
    }

    .modal-title {
        font-weight: 800;
        color: #1e1b4b;
    }

    .modal-body {
        padding: 1.5rem;
        max-height: 70vh;
        overflow-y: auto;
    }

    .form-label {
        font-size: 0.75rem;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
        margin-bottom: 0.25rem;
    }

    .form-control, .form-select {
        border-radius: 0.5rem;
        border: 1px solid #e2e8f0;
        font-size: 0.875rem;
        padding: 0.5rem 0.75rem;
    }

    .form-control:focus {
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
    }

    .glass {
        backdrop-filter: blur(10px);
        background: var(--bg-glass);
    }
</style>

<div class="main-content">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show m-3 border-0 shadow-sm" style="border-radius: 0.75rem; background: #f0fdf4; color: #166534;" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show m-3 border-0 shadow-sm" style="border-radius: 0.75rem; background: #fef2f2; color: #991b1b;" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="premium-header">
        <div>
            <h1><i class="fas fa-users-cog me-2"></i>User Management</h1>
            <p>System Administration Portal &bull; Comprehensive Control</p>
        </div>
        <button class="btn-add" onclick="openAddModal()">
            <i class="fas fa-plus-circle"></i> Add New User
        </button>
    </div>

    <div class="table-container">
        <div class="toolbar">
            <div class="search-box">
                <i class="fas fa-search"></i>
                <input type="text" id="gridSearch" placeholder="Filter users by name, username, or role...">
            </div>
            <div class="text-muted" style="font-size: 0.75rem;">
                Total: <span id="userCount" class="fw-bold text-dark">@Model.Count</span> active accounts
            </div>
        </div>

        <div class="table-responsive" style="max-height: calc(100vh - 300px);">
            <table class="grid-table" id="userTable">
                <thead>
                    <tr>
                        <th style="width: 40px;">ID</th>
                        <th>User Name</th>
                        <th>Full Name</th>
                        <th>Role</th>
                        <th>Person ID</th>
                        <th>Gender</th>
                        <th>Status</th>
                        <th>Branch</th>
                        <th>Phone</th>
                        <th>Remark</th>
                        <th>Last Login</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr class="user-row" data-json='@Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(user))'>
                            <td>@user.Id</td>
                            <td class="fw-bold text-primary">@user.UserName</td>
                            <td>@(string.IsNullOrEmpty(user.FullName) ? "N/A" : user.FullName)</td>
                            <td>
                                <span class="badge rounded-pill" style="background: #eef2ff; color: #4f46e5; border: 1px solid #c7d2fe; font-size: 9px;">
                                    @(string.IsNullOrEmpty(user.RoleName) ? "User" : user.RoleName)
                                </span>
                            </td>
                            <td>@user.Person</td>
                            <td>@(user.Gender == 1 ? "M" : (user.Gender == 2 ? "F" : "-"))</td>
                            <td>
                                @if (user.IsActive)
                                {
                                    <span class="status-badge status-active"><i class="fas fa-check-circle"></i> Active</span>
                                }
                                else
                                {
                                    <span class="status-badge status-inactive"><i class="fas fa-times-circle"></i> Inactive</span>
                                }
                            </td>
                            <td>@user.Branch</td>
                            <td>@user.Phone1</td>
                            <td title="@user.Remark">@user.Remark</td>
                            <td>@(user.LastLoginAt?.ToString("yy/MM/dd HH:mm") ?? "Never")</td>
                            <td class="text-end">
                                <button class="action-btn" title="Edit" onclick="editUser(this)">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="action-btn delete" title="Delete" onclick="deleteUser(@user.Id)">
                                    <i class="fas fa-trash-alt"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        let userModal, deleteModal;

        document.addEventListener('DOMContentLoaded', function () {
            try {
                userModal = new bootstrap.Modal(document.getElementById('userModal'));
                deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));
            } catch (e) {
                console.error("Bootstrap Modal initialization failed:", e);
                // Fallback for older Bootstrap or if bootstrap is not on global scope
                userModal = { show: () => $('#userModal').modal('show'), hide: () => $('#userModal').modal('hide') };
                deleteModal = { show: () => $('#deleteModal').modal('show'), hide: () => $('#deleteModal').modal('hide') };
            }
        });

        function openAddModal() {
            document.getElementById('userForm').reset();
            document.getElementById('field_Id').value = 0;
            document.getElementById('field_Person').value = 0;
            document.getElementById('field_Branch').value = 0;
            document.getElementById('modalTitle').textContent = 'Add New User';
            if (userModal) userModal.show();
        }

        function editUser(btn) {
            try {
                const row = btn.closest('tr');
                const data = JSON.parse(row.dataset.json);
                
                document.getElementById('modalTitle').textContent = 'Edit User: ' + data.UserName;
                document.getElementById('field_Id').value = data.Id;
                document.getElementById('field_Person').value = data.Person || 0;
                document.getElementById('field_Branch').value = data.Branch || 0;
                document.getElementById('field_UserName').value = data.UserName;
                document.getElementById('field_Password').value = ''; 
                document.getElementById('field_RoleName').value = data.RoleName || '';
                document.getElementById('field_FirstName').value = data.FirstName;
                document.getElementById('field_SecondName').value = data.SecondName;
                document.getElementById('field_Phone1').value = data.Phone1;
                document.getElementById('field_IsActive').checked = data.IsActive;
                document.getElementById('field_Remark').value = data.Remark;

                if (userModal) userModal.show();
            } catch (e) {
                console.error("Error in editUser:", e);
            }
        }

        function deleteUser(id) {
            document.getElementById('deleteUserId').value = id;
            if (deleteModal) deleteModal.show();
        }

        document.getElementById('gridSearch').addEventListener('input', function() {
            const query = this.value.toLowerCase();
            const rows = document.querySelectorAll('.user-row');
            let visibleCount = 0;

            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                if (text.includes(query)) {
                    row.style.display = '';
                    visibleCount++;
                } else {
                    row.style.display = 'none';
                }
            });
            document.getElementById('userCount').textContent = visibleCount;
        });
    </script>
}

<!-- User Modal -->
<div class="modal fade" id="userModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content glass">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">User Information</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="userForm" asp-action="SaveUser" method="post">
                <input type="hidden" name="Id" id="field_Id" value="0" />
                <input type="hidden" name="Person" id="field_Person" value="0" />
                <input type="hidden" name="Branch" id="field_Branch" value="0" />
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Username</label>
                            <input type="text" name="UserName" id="field_UserName" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Password</label>
                            <input type="password" name="Password" id="field_Password" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Role</label>
                            <select name="RoleName" id="field_RoleName" class="form-select">
                                <option value="">Select Role...</option>
                                @if (ViewBag.Roles != null)
                                {
                                    foreach (var role in (List<CNET_V7_Domain.Domain.ConsigneeSchema.ConsigneeUnitDTO>)ViewBag.Roles)
                                    {
                                        <option value="@(string.IsNullOrEmpty(role.Description) ? role.Name : role.Description)">@(string.IsNullOrEmpty(role.Description) ? role.Name : role.Description)</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">First Name</label>
                            <input type="text" name="FirstName" id="field_FirstName" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Second Name</label>
                            <input type="text" name="SecondName" id="field_SecondName" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Phone</label>
                            <input type="text" name="Phone1" id="field_Phone1" class="form-control" />
                        </div>
                        <div class="col-md-12">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="IsActive" id="field_IsActive" value="true" checked>
                                <label class="form-check-label fw-bold" for="field_IsActive">Account Active</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Remark</label>
                            <textarea name="Remark" id="field_Remark" class="form-control" rows="2"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4 fw-bold">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-body text-center p-4">
                <i class="fas fa-exclamation-triangle text-danger mb-3" style="font-size: 2.5rem;"></i>
                <h5 class="mb-2">Are you sure?</h5>
                <p class="text-muted small">This action cannot be undone. This user will be permanently removed.</p>
                <form id="deleteForm" asp-action="DeleteUser" method="post">
                    <input type="hidden" name="id" id="deleteUserId" />
                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-danger fw-bold">Yes, Delete User</button>
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
