@model Ministry_of_Tourism_pro.Models.CreateSystemUserViewModel
@{
    ViewData["Title"] = "Add Member";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .sa-header {
        background: linear-gradient(135deg, #1e1b4b 0%, #4338ca 100%);
        border-radius: 1.25rem;
        padding: 1.75rem 2.5rem;
        color: white;
        margin-bottom: 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .sa-header h1 { font-size: 1.4rem; font-weight: 800; margin: 0 0 .2rem; letter-spacing: -0.5px; }
    .sa-header p  { margin: 0; opacity: .7; font-size: .85rem; }

    .btn-back {
        display: inline-flex; align-items: center; gap: .5rem; padding: .5rem 1rem;
        border-radius: .7rem; background: rgba(255,255,255,.15); color: white;
        font-size: .8rem; font-weight: 700; border: 1px solid rgba(255,255,255,.25); text-decoration: none; transition: all .15s;
    }
    .btn-back:hover { background: rgba(255,255,255,.25); color: white; }

    .form-card {
        background: white;
        border-radius: 1rem;
        border: 1px solid #e2e8f0;
        box-shadow: 0 2px 8px rgba(0,0,0,.06);
        overflow: hidden;
        max-width: 850px;
    }
    .form-section {
        padding: 1.5rem;
        border-bottom: 1px solid #f1f5f9;
    }
    .form-section:last-child { border-bottom: none; }
    .section-label {
        font-size: .65rem; font-weight: 800; text-transform: uppercase;
        letter-spacing: .08em; color: #94a3b8; margin-bottom: 1.25rem;
        display: flex; align-items: center; gap: .5rem;
    }
    .section-label::after { content: ''; flex: 1; height: 1px; background: #f1f5f9; }

    /* override site form-control for consistency */
    .sa-input {
        width: 100%;
        padding: .6rem .9rem;
        font-size: .875rem;
        border: 1.5px solid #e2e8f0;
        border-radius: .65rem;
        transition: all .15s;
        outline: none;
        box-sizing: border-box;
        color: #1e293b;
        background: white;
    }
    .sa-input:focus { border-color: #4f46e5; box-shadow: 0 0 0 3px rgba(79,70,229,.08); }
    .input-label {
        display: block; font-size: .72rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: .05em; color: #64748b; margin-bottom: .4rem;
    }
    .input-hint { font-size: .72rem; color: #94a3b8; margin-top: .3rem; }

    .btn-submit {
        padding: .7rem 2rem; border-radius: .75rem; background: #4f46e5; color: white;
        font-weight: 700; font-size: .9rem; border: none; cursor: pointer; transition: all .15s;
        display: inline-flex; align-items: center; gap: .5rem;
    }
    .btn-submit:hover { background: #4338ca; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(79,70,229,.3); }
    .btn-discard {
        padding: .7rem 1.5rem; border-radius: .75rem; background: #f1f5f9; color: #64748b;
        font-weight: 700; font-size: .9rem; border: 1px solid #e2e8f0; text-decoration: none;
        display: inline-flex; align-items: center; gap: .5rem; transition: all .15s;
    }
    .btn-discard:hover { background: #e2e8f0; color: #334155; }
    .text-danger-sm { color: #ef4444; font-size: .72rem; margin-top: .2rem; display: block; }
</style>

<div class="main-content" style="padding: 1.5rem 2rem;">

    <!-- Page Header -->
    <div class="sa-header mb-4">
        <div>
            <h1><i class="fas fa-user-plus me-3"></i>Add New Member</h1>
            <p>Create a personnel record (gslType = 26) with system login credentials</p>
        </div>
        <a asp-action="MaintainUsers" asp-route-consigneeId="@Model.ConsigneeId" class="btn-back">
            <i class="fas fa-arrow-left"></i> Back to Members
        </a>
    </div>

    <form asp-action="CreateUser" method="post">
        <input type="hidden" asp-for="ConsigneeId" />
        <div class="form-card">

            <!-- Section 1: Identity -->
            <div class="form-section">
                <div class="section-label"><i class="fas fa-id-card" style="color:#4f46e5;"></i> Personal Information</div>
                <div class="row g-3">
                    <div class="col-md-8">
                        <label class="input-label">Legal Full Name <span style="color:#ef4444;">*</span></label>
                        <input asp-for="FullName" class="sa-input" placeholder="e.g. Samuel Kebede" />
                        <span asp-validation-for="FullName" class="text-danger-sm"></span>
                    </div>
                    <div class="col-md-4">
                        <label class="input-label">Initial Role <span style="color:#ef4444;">*</span></label>
                        <select asp-for="RoleId" class="sa-input">
                            <option value="2">System Administrator</option>
                            <option value="4">Administrator</option>
                            <option value="7" selected>Supervisor</option>
                            <option value="8">General Manager</option>
                            <option value="5">Standard User (L1)</option>
                            <option value="6">Standard User (L2)</option>
                        </select>
                        <span class="input-hint">Sets the starting privilege profile</span>
                    </div>
                    <div class="col-md-6">
                        <label class="input-label">Email Address</label>
                        <input asp-for="Email" class="sa-input" type="email" placeholder="samuel.k@tourism.gov.et" />
                    </div>
                    <div class="col-md-6">
                        <label class="input-label">Phone Number</label>
                        <input asp-for="Phone" class="sa-input" placeholder="+251 9…" />
                    </div>
                </div>
            </div>

            <!-- Section 2: Credentials -->
            <div class="form-section" style="background:#fafbfc;">
                <div class="section-label"><i class="fas fa-lock" style="color:#4f46e5;"></i> Login Credentials</div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="input-label">Username <span style="color:#ef4444;">*</span></label>
                        <input asp-for="UserName" class="sa-input" placeholder="e.g. skebede" autocomplete="off" />
                        <span asp-validation-for="UserName" class="text-danger-sm"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="input-label">Temporary Password <span style="color:#ef4444;">*</span></label>
                        <input asp-for="Password" class="sa-input" type="password" placeholder="••••••••" autocomplete="new-password" />
                        <span asp-validation-for="Password" class="text-danger-sm"></span>
                        <span class="input-hint">Advise the user to change this upon first login.</span>
                    </div>
                </div>
            </div>

            <!-- Footer Actions -->
            <div class="form-section d-flex justify-content-between align-items-center">
                <a asp-action="MaintainUsers" asp-route-consigneeId="@Model.ConsigneeId" class="btn-discard">
                    <i class="fas fa-times"></i> Discard
                </a>
                <button type="submit" class="btn-submit">
                    <i class="fas fa-check-circle"></i> Create Account
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
