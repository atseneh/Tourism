@model Ministry_of_Tourism_pro.Models.ConsigneeEditViewModel
@{
    ViewData["Title"] = "Register Organization";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="mt-4">Register New Consignee</h1>
            <p class="text-muted">Create a new organization record in the system</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back to List
        </a>
    </div>

    <div class="card border-0 shadow-sm mb-4" style="max-width: 800px;">
        <div class="card-header bg-success text-white py-3">
            <h6 class="m-0 font-weight-bold">Consignee Details (gslType = 28)</h6>
        </div>
        <div class="card-body p-4">
            <form asp-action="CreateConsignee" method="post">
                <div class="row">
                    <div class="col-md-12 mb-3">
                        <label asp-for="Name" class="form-label fw-bold">Legal Name / Organization Name</label>
                        <input asp-for="Name" class="form-control" placeholder="e.g. Addis Hilton Hotel" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="col-md-12 mb-3">
                        <label asp-for="TIN" class="form-label fw-bold">TIN Number</label>
                        <input asp-for="TIN" class="form-control" placeholder="10-digit TIN" />
                        <span asp-validation-for="TIN" class="text-danger"></span>
                    </div>

                    <div class="col-md-12 mb-3">
                        <label asp-for="Remark" class="form-label fw-bold">Description / Additional Notes</label>
                        <textarea asp-for="Remark" class="form-control" rows="3" placeholder="Enter any notes about this organization..."></textarea>
                    </div>

                    <div class="col-md-12 mb-3">
                        <div class="form-check form-switch p-0 ps-4">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" checked id="isActiveSwitch">
                            <label class="form-check-label fw-bold" for="isActiveSwitch">Set as Active immediately</label>
                        </div>
                    </div>
                </div>

                <div class="mt-4 border-top pt-4 text-end">
                    <button type="submit" class="btn btn-success px-5 btn-lg">
                        <i class="fas fa-save me-2"></i>Register Consignee
                    </button>
                    <a asp-action="Index" class="btn btn-light px-4 btn-lg">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
