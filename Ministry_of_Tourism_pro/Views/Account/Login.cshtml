@model Ministry_of_Tourism_pro.Models.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Login";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - AATMCDP</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --navy-deep: #0f172a;
            --primary-color: #3b82f6;
            --text-muted: #64748b;
            --border-color: #e2e8f0;
        }

        body {
            font-family: 'Outfit', sans-serif;
            margin: 0;
            padding: 0;
            background-color: var(--navy-deep);
            overflow: hidden;
        }

        .auth-wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }

        /* Background Slider */
        .bg-slider {
            position: absolute;
            inset: 0;
            z-index: 0;
        }

        .slide {
            position: absolute;
            inset: 0;
            background-size: cover;
            background-position: center;
            opacity: 0;
            transition: opacity 2s ease-in-out;
            transform: scale(1.1);
            animation: panSlow 30s linear infinite;
        }

        .slide.active {
            opacity: 1;
        }

            .slide:nth-child(1) {
                background-image: url('/images/backgrounds/adwa5.jpg');}
        .slide:nth-child(2) { background-image: url('/images/backgrounds/new_addis_ababa_03.jfif'); }
        .slide:nth-child(3) { background-image: url('/images/backgrounds/Addis_Ababa_02S.jpg'); }

        .bg-overlay {
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at center, rgba(15, 23, 42, 0.3) 0%, rgba(70, 76, 92, 0.8) 100%);
            z-index: 1;
        }

        @@keyframes panSlow {
            0% { transform: scale(1.1) translateX(0); }
            50% { transform: scale(1.2) translateX(-2%); }
            100% { transform: scale(1.1) translateX(0); }
        }

        .auth-card {
            width: 100%;
            max-width: 440px;
            padding: 3.5rem;
            position: relative;
            z-index: 10;
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.88);
            backdrop-filter: blur(20px) saturate(180%);
            border-radius: 32px;
            border: 1px solid rgba(255, 255, 255, 0.4);
            box-shadow: 0 40px 100px -20px rgba(0, 0, 0, 0.3);
        }

        .brand-logo-circle {
            width: 100px;
            height: 100px;
            margin: 0 auto 1.5rem;
            background: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
            padding: 12px;
            animation: float 6s ease-in-out infinite;
        }

        @@keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }

        .brand-logo-circle img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

        .portal-title {
            color: var(--navy-deep);
            margin: 0;
            font-weight: 800;
            font-size: 1.6rem;
            line-height: 1.25;
            letter-spacing: -0.8px;
            text-align: center;
        }

        .form-group { margin-bottom: 1.5rem; }
        .form-label { display: block; font-weight: 700; font-size: 0.8rem; color: var(--navy-deep); margin-bottom: 0.6rem; text-transform: uppercase; letter-spacing: 1px; }
        
        .form-control {
            width: 100%;
            padding: 1rem 1.25rem;
            border-radius: 16px;
            border: 1px solid var(--border-color);
            background: rgba(248, 250, 252, 0.8);
            color: var(--navy-deep);
            font-family: inherit;
            font-size: 1rem;
            box-sizing: border-box;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .form-control::placeholder { color: #94a3b8; }
        .form-control:focus { outline: none; border-color: var(--primary-color); background: white; box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1); }

        .btn-premium {
            width: 100%;
            background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
            color: white;
            border: none;
            padding: 1.1rem;
            border-radius: 16px;
            font-weight: 800;
            font-size: 1.1rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
            font-family: inherit;
            margin-top: 1.5rem;
            box-shadow: 0 10px 25px -5px rgba(37, 99, 235, 0.4);
        }
        .btn-premium:hover { transform: translateY(-3px); box-shadow: 0 15px 30px -5px rgba(37, 99, 235, 0.6); }
        .btn-premium:active { transform: translateY(-1px); }

        .animate-fade-in { animation: fadeIn 1s cubic-bezier(0.16, 1, 0.3, 1); }
        @@keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body>
    <div class="auth-wrapper">
        <div class="bg-slider">
            <div class="slide active"></div>
            <div class="slide"></div>
            <div class="slide"></div>
        </div>
        <div class="bg-overlay"></div>
        
        <div class="glass-card auth-card animate-fade-in">
            <div style="text-align: center; margin-bottom: 2.5rem;">
                <div class="brand-logo-circle">
                    <img src="/logo/logo.svg" alt="AATMCDP Logo" />
                </div>
                <h1 class="portal-title">Addis Ababa Tourism & MICE Portal</h1>
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div style="background: #ecfdf5; border: 1px solid #10b981; color: #065f46; padding: 1rem; border-radius: 12px; margin-bottom: 1.5rem; font-size: 0.9rem; font-weight: 600; text-align: center;">
                    <i class="fas fa-check-circle" style="margin-right: 0.5rem;"></i>
                    @TempData["SuccessMessage"]
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div style="background: #fef2f2; border: 1px solid #ef4444; color: #b91c1c; padding: 1rem; border-radius: 12px; margin-bottom: 1.5rem; font-size: 0.9rem; font-weight: 600; text-align: center;">
                    <i class="fas fa-exclamation-circle" style="margin-right: 0.5rem;"></i>
                    @TempData["ErrorMessage"]
                </div>
            }

            <form asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" style="color: #ef4444; font-size: 0.85rem; margin-bottom: 1rem; text-align: center;"></div>
                
                @* Hidden Branch input - Hardcoded to 3 in Controller *@
                <input type="hidden" asp-for="Branch" />

                <div class="form-group">
                    <label asp-for="Email" class="form-label">UserName or Email</label>
                    <input asp-for="Email" class="form-control" placeholder="username@example.com" />
                </div>

                <div class="form-group">
                    <label asp-for="Password" class="form-label">Password</label>
                    <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" />
                </div>

                <div class="form-group" style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
                    <input asp-for="RememberMe" style="width: 1.1rem; height: 1.1rem; cursor: pointer;" />
                    <label asp-for="RememberMe" style="font-size: 0.9rem; color: var(--text-muted); cursor: pointer; font-weight: 500;">Remember me on this device</label>
                </div>

                <button type="submit" class="btn-premium">
                    <span>Sign In</span>
                    <i class="fas fa-arrow-right" style="margin-left: 0.75rem; font-size: 0.9rem;"></i>
                </button>

                <div style="text-align: center; margin-top: 1.5rem;">
                    <p style="color: var(--text-muted); font-size: 0.9rem; font-weight: 500;">
                        No account? <a asp-action="PreRegister" style="color: var(--primary-color); text-decoration: none; font-weight: 700;">Pre-register here</a>
                    </p>
                </div>
            </form>

            <div style="text-align: center; margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid var(--border-color);">
                <p style="color: var(--text-muted); font-size: 0.85rem; font-weight: 500;">&copy; @DateTime.Now.Year AATMCDP </p>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const slides = document.querySelectorAll('.slide');
            let currentSlide = 0;

            function nextSlide() {
                slides[currentSlide].classList.remove('active');
                currentSlide = (currentSlide + 1) % slides.length;
                slides[currentSlide].classList.add('active');
            }

            // Change slide every 7 seconds
            setInterval(nextSlide, 7000);
        });
    </script>
</body>
</html>
