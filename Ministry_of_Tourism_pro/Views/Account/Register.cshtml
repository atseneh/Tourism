@model Ministry_of_Tourism_pro.Models.RegisterViewModel
@{
    Layout = null;
    ViewData["Title"] = "Register";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register - Ministry of Tourism</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>
    <div class="auth-wrapper" style="padding: 3rem 1rem;">
        <div class="glass-card auth-card animate-fade-in" style="max-width: 500px;">
            <div style="text-align: center; margin-bottom: 2.5rem;">
                <div class="brand-icon" style="margin: 0 auto 1.5rem; width: 48px; height: 48px; font-size: 1.5rem;">
                    <i class="fas fa-landmark"></i>
                </div>
                <h1 style="color: var(--navy-deep); margin: 0; font-weight: 800; letter-spacing: -1px;">Create Account</h1>
                <p style="color: var(--text-muted); margin-top: 0.5rem;">Join the Ethiopia Tourism Network</p>
            </div>

            <form asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
                
                <div class="form-group">
                    <label asp-for="FullName" class="form-label">Full Name</label>
                    <input asp-for="FullName" class="form-control" placeholder="Abebe Bikila" />
                    <span asp-validation-for="FullName" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Email" class="form-label">Email Address</label>
                    <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Role" class="form-label">Account Type</label>
                    <select asp-for="Role" class="form-control">
                        <option value="HotelOwner">Hotel Owner</option>
                        <option value="Commissioner">Ministry Official</option>
                    </select>
                </div>

                <div class="form-group" id="tin-group">
                    <label asp-for="TIN" class="form-label">TIN Number</label>
                    <input asp-for="TIN" class="form-control" placeholder="123456789" />
                    <span asp-validation-for="TIN" class="field-validation-error"></span>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="form-group">
                        <label asp-for="Password" class="form-label">Password</label>
                        <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" />
                        <span asp-validation-for="Password" class="field-validation-error"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="ConfirmPassword" class="form-label">Confirm</label>
                        <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="••••••••" />
                        <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
                    </div>
                </div>

                <button type="submit" class="btn-premium" style="margin-top: 1rem;">
                    <span>Create Account</span>
                    <i class="fas fa-user-plus" style="margin-left: 0.75rem; font-size: 0.9rem;"></i>
                </button>
            </form>

            <div style="text-align: center; margin-top: 2.5rem; padding-top: 1.5rem; border-top: 1px solid var(--border-color);">
                <p style="color: var(--text-muted); font-size: 0.95rem;">Already have an account? <a asp-action="Login" style="color: var(--primary-color); font-weight: 700; text-decoration: none;">Login here</a></p>
            </div>
        </div>
    </div>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        $(document).ready(function() {
            $('#Role').change(function() {
                if ($(this).val() === 'HotelOwner') {
                    $('#tin-group').slideDown();
                } else {
                    $('#tin-group').slideUp();
                }
            }).trigger('change');
        });
    </script>
</body>
</html>
