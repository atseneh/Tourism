@model CNET_V7_Domain.Domain.ViewSchema.VwConsigneeViewDTO
@{
    ViewData["Title"] = "Sector Application Audit - " + Model.FirstName;
}

<div class="animate-fade-in">
    <!-- Back to Overview Header -->
    <div style="margin-bottom: 2rem; display: flex; align-items: center; justify-content: space-between;">
        <a asp-action="PendingApprovals" style="text-decoration: none; color: var(--text-muted); font-weight: 600; display: flex; align-items: center; gap: 0.5rem; transition: var(--transition);" onmouseover="this.style.color='var(--primary-color)'" onmouseout="this.style.color='var(--text-muted)'">
            <i class="fas fa-arrow-left"></i> Back to Approval Queue
        </a>
        <div style="display: flex; gap: 1rem;">
            <span class="badge badge-pending" style="font-size: 0.85rem; padding: 0.5rem 1.25rem;">DETAILED AUDIT</span>
        </div>
    </div>

    <div class="glass-card" style="padding: 0; overflow: hidden; border-radius: 1.5rem;">
        <!-- Hero Section -->
        <div style="height: 350px; position: relative; overflow: hidden; background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);">
            <div style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; opacity: 0.05;">
                <i class="fas fa-building-circle-check" style="font-size: 25rem; color: white;"></i>
            </div>
            <div style="position: absolute; inset: 0; background: linear-gradient(to bottom, transparent 30%, rgba(15, 23, 42, 0.95) 100%);"></div>
            <div style="position: absolute; bottom: 3rem; left: 3rem; right: 3rem; color: white;">
                <h1 style="font-weight: 800; font-size: 3rem; margin: 0; letter-spacing: -2px;">@Model.FirstName</h1>
                <div style="display: flex; flex-wrap: wrap; gap: 2rem; margin-top: 1.25rem; font-size: 1.1rem; opacity: 0.9;">
                    <span><i class="fas fa-fingerprint" style="margin-right: 0.6rem; color: var(--primary-color);"></i>TIN: <strong>@Model.Tin</strong></span>
                    <span><i class="fas fa-hashtag" style="margin-right: 0.6rem; color: var(--primary-color);"></i>Code: <strong>@Model.Code</strong></span>
                    <span><i class="fas fa-map-location-dot" style="margin-right: 0.6rem; color: var(--primary-color);"></i>@(Model.SpecificAddress ?? "Registry Zone")</span>
                    <span><i class="fas fa-code-branch" style="margin-right: 0.6rem; color: var(--primary-color);"></i>Preference ID: @Model.ChildPreferenceDescrption</span>
                </div>
            </div>
        </div>

        <div style="padding: 3.5rem;">
            <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 4rem;">
                
                <!-- Left Column: Comprehensive Data -->
                <div>
                    <!-- Section: Core Identity -->
                    <section style="margin-bottom: 3.5rem;">
                        <h3 style="font-weight: 800; color: var(--navy-deep); margin-bottom: 2rem; display: flex; align-items: center; gap: 0.75rem;">
                            <i class="fas fa-id-card-clip" style="color: var(--primary-color);"></i> Core Entity Identity
                        </h3>
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
                            <div class="data-group">
                                <label style="display: block; font-size: 0.7rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem;">First Name / Establishment</label>
                                <div style="font-size: 1.1rem; font-weight: 700; color: var(--navy-deep); padding: 1.25rem; background: var(--bg-muted); border-radius: 1rem;">@Model.FirstName</div>
                            </div>
                            <div class="data-group">
                                <label style="display: block; font-size: 0.7rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem;">Database Reference (ID)</label>
                                <div style="font-size: 1.1rem; font-weight: 700; color: var(--navy-deep); padding: 1.25rem; background: var(--bg-muted); border-radius: 1rem;">#@Model.Id</div>
                            </div>
                            <div class="data-group">
                                <label style="display: block; font-size: 0.7rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem;">Preference Configuration</label>
                                <div style="font-size: 1.1rem; font-weight: 700; color: var(--navy-deep); padding: 1.25rem; background: var(--bg-muted); border-radius: 1rem;">@Model.ChildConsigeeUnitpreferencId (ID: @Model.ChildPreferenceDescrption)</div>
                            </div>
                            <div class="data-group">
                                <label style="display: block; font-size: 0.7rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem;">Status Indicator</label>
                                <div style="font-size: 1.1rem; font-weight: 700; color: #10b981; padding: 1.25rem; background: #f0fdf4; border-radius: 1rem; display: flex; align-items: center; gap: 0.5rem;">
                                    <i class="fas fa-circle-check"></i> ACTIVE REGISTRY
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- Section: Additional Details & Remarks -->
                    <section style="margin-bottom: 3.5rem;">
                        <h3 style="font-weight: 800; color: var(--navy-deep); margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.75rem;">
                            <i class="fas fa-file-lines" style="color: var(--primary-color);"></i> Application Remarks
                        </h3>
                        <div style="background: white; border: 2px solid var(--border-color); border-radius: 1.5rem; padding: 2.5rem; font-size: 1.1rem; line-height: 1.8; color: var(--text-dark); position: relative;">
                            <i class="fas fa-quote-left" style="position: absolute; top: 1rem; left: 1rem; opacity: 0.1; font-size: 2rem;"></i>
                            @(string.IsNullOrEmpty(Model.ConsigneeRemark) ? "No additional narrative or remarks were provided during the sector registration process." : Model.ConsigneeRemark)
                        </div>
                    </section>
                </div>

                <!-- Right Column: Audit Summary Portal -->
                <div>
                    <div style="position: sticky; top: 2rem;">
                        <div class="glass-card" style="padding: 2.5rem; background: #f8fafc; border: 1px solid var(--border-color); border-radius: 1.5rem;">
                            <h4 style="font-weight: 800; color: var(--navy-deep); margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 1rem; font-size: 1.2rem;">Sector Registry Audit</h4>
                            
                            <div style="display: flex; flex-direction: column; gap: 1.75rem;">
                                <div>
                                    <div style="font-size: 0.7rem; color: var(--text-muted); font-weight: 700; text-transform: uppercase; margin-bottom: 0.5rem;">Primary Location</div>
                                    <div style="font-weight: 700; color: var(--navy-deep); font-size: 1.1rem; display: flex; align-items: center; gap: 0.6rem;">
                                        <i class="fas fa-location-dot" style="color: var(--primary-color);"></i> @(Model.SpecificAddress ?? "Addis Ababa Central")
                                    </div>
                                </div>
                                <div style="padding: 1.25rem; background: #eff6ff; border-radius: 1rem; border: 1px solid #dbeafe;">
                                    <div style="font-size: 0.7rem; color: #1e40af; font-weight: 700; text-transform: uppercase; margin-bottom: 0.5rem;">Auditor's Compliance Note</div>
                                    <p style="margin: 0; font-size: 0.9rem; color: #1e3a8a; line-height: 1.5; font-weight: 500;">
                                        Please verify that the TIN registry matches the official Ministry of Revenue records before confirming certification.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <!-- Quick Actions in Sidebar -->
                        <div style="margin-top: 2rem; display: grid; gap: 1rem;">
                            <form asp-action="Approve" asp-route-id="@Model.Id" method="post">
                                <button type="submit" class="btn-premium" style="width: 100%; justify-content: center; background: #10b981; padding: 1.25rem; font-size: 1.1rem; box-shadow: 0 10px 25px rgba(16, 185, 129, 0.25);">
                                    <i class="fas fa-check-double" style="margin-right: 0.75rem;"></i> Certify Application
                                </button>
                            </form>
                            <button onclick="showRejectModal()" class="btn-premium" style="width: 100%; justify-content: center; background: #ef4444; padding: 1rem; font-weight: 700; border-radius: 12px;">
                                <i class="fas fa-ban" style="margin-right: 0.75rem;"></i> Decline Registry
                            </button>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<!-- Reject Modal -->
<div id="reject-modal" style="display:none; position: fixed; inset: 0; background: rgba(15, 23, 42, 0.82); backdrop-filter: blur(8px); z-index: 2000; align-items: center; justify-content: center; padding: 1.5rem;">
    <div class="glass-card animate-fade-in" style="width: 100%; max-width: 600px; padding: 3.5rem;">
        <div style="text-align: center; margin-bottom: 2.5rem;">
            <div style="width: 80px; height: 80px; background: #fef2f2; color: #ef4444; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; font-size: 2.5rem;">
                <i class="fas fa-triangle-exclamation"></i>
            </div>
            <h2 style="color: var(--navy-deep); margin: 0; font-weight: 800; font-size: 1.75rem;">Decline Application</h2>
            <p style="color: var(--text-muted); margin-top: 0.5rem; font-size: 1.1rem;">Confirmation required to reject "@Model.FirstName"</p>
        </div>

        <form asp-action="Reject" method="post" id="reject-form">
            <input type="hidden" name="id" value="@Model.Id" />
            <div class="form-group">
                <label class="form-label" style="font-weight: 700; margin-bottom: 0.75rem;">Official Audit Conclusion</label>
                <textarea name="comment" class="form-control" rows="6" required 
                          placeholder="Provide a detailed explanation for the rejection. This will be visible to the property owner..."
                          style="border-radius: 1rem; padding: 1.5rem; font-size: 1rem; border: 2px solid var(--border-color);"></textarea>
            </div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-top: 2.5rem;">
                <button type="button" onclick="closeRejectModal()" class="btn-premium btn-secondary" style="border-radius: 12px;">Discard Action</button>
                <button type="submit" class="btn-premium" style="background: #ef4444; font-weight: 800; border-radius: 12px;">Confirm Rejection</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function showRejectModal() {
            $('#reject-modal').css('display', 'flex').hide().fadeIn(300);
        }
        function closeRejectModal() {
            $('#reject-modal').fadeOut(300);
        }
    </script>
}
